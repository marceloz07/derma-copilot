# =============================================================================
#  DERMA COPILOT — Variables de entorno
#  Copia este archivo a .env y rellena los valores.
#
#  Marcadores:
#    [REQUERIDA]  → la app lanza error al iniciar si falta
#    [opcional]   → tiene valor por defecto razonable
#    [futura]     → no se usa aún; preparada para próximas features
#
#  NUNCA commitees el archivo .env al repositorio.
#  Genera secretos seguros con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================================================


# ─── Servidor ─────────────────────────────────────────────────────────────────

APP_NAME=Derma Copilot API
API_VERSION=v1

# Puerto en que escucha el servidor HTTP
PORT=3000                         # [opcional] default: 3000

# Entorno de ejecución: development | test | production
NODE_ENV=development              # [opcional] default: development

# Nivel de log: error | warn | info | http | debug
# En producción usar "warn" o "error" para evitar ruido
LOG_LEVEL=debug                   # [opcional] default: info


# ─── JWT ──────────────────────────────────────────────────────────────────────

# Clave para firmar los access tokens — mínimo 32 caracteres aleatorios
JWT_SECRET=                       # [REQUERIDA]

# Duración del access token (formato ms o vercel/ms: 15m, 1h, 7d)
JWT_EXPIRES_IN=15m                # [opcional] default: 7d  ← reducir en producción

# Clave para firmar los refresh tokens — DIFERENTE a JWT_SECRET
JWT_REFRESH_SECRET=               # [REQUERIDA]

# Duración del refresh token
JWT_REFRESH_EXPIRES_IN=30d        # [opcional] default: 30d


# ─── Base de Datos ────────────────────────────────────────────────────────────

# PostgreSQL (Prisma / TypeORM)
DATABASE_URL=postgresql://user:password@localhost:5432/derma_copilot   # [REQUERIDA en prod]

# MongoDB (Mongoose) — alternativa; usa uno u otro, no ambos
# MONGO_URI=mongodb://localhost:27017/derma_copilot


# ─── Redis ────────────────────────────────────────────────────────────────────
# Necesario para:
#   · Blacklist de tokens revocados (logout real)   ← TODO en auth.controller.ts
#   · Rate limiting distribuido en múltiples nodos
#   · Cache de respuestas frecuentes (perfiles, catálogos)

REDIS_URL=redis://localhost:6379  # [futura] default: sin redis (stateless)
REDIS_PASSWORD=                   # [futura] dejar vacío si Redis no tiene contraseña


# ─── CORS ─────────────────────────────────────────────────────────────────────

# Origen(es) permitidos para CORS
# Desarrollo:   http://localhost:5173
# Producción:   https://app.dermacopilot.com
# Multi-origen: separar con coma → https://app.com,https://admin.app.com
CORS_ORIGIN=http://localhost:5173   # [opcional] default: http://localhost:5173


# ─── Rate Limiting ────────────────────────────────────────────────────────────

# Ventana de tiempo en milisegundos para el rate limiter GLOBAL
RATE_LIMIT_WINDOW_MS=900000         # [opcional] default: 900000 (15 minutos)

# Máximo de peticiones por IP en la ventana GLOBAL
RATE_LIMIT_MAX=100                  # [opcional] default: 100

# Máximo de intentos fallidos por IP en rutas de AUTH (login, register)
# Más estricto que el global para mitigar fuerza bruta
AUTH_RATE_LIMIT_MAX=10              # [opcional] default: 10


# ─── Seguridad ────────────────────────────────────────────────────────────────

# Rondas de hashing para bcrypt (10-14 en prod, 6-8 en tests para velocidad)
BCRYPT_SALT_ROUNDS=12               # [opcional] default: 12

# Clave AES-256 para cifrar datos médicos sensibles en reposo (32 bytes hex)
# Datos que requieren cifrado: diagnósticos, imágenes, notas clínicas
ENCRYPTION_KEY=                     # [futura, REQUERIDA al activar cifrado en BD]

# Semilla para HMAC de tokens de un solo uso (OTP, reset password)
OTP_SECRET=                         # [futura, REQUERIDA al activar email/OTP]


# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Usado para: recuperación de contraseña, verificación de cuenta, notificaciones
#
# Proveedores recomendados: Resend, SendGrid, Postmark, Gmail SMTP
# Resend:   SMTP_HOST=smtp.resend.com  SMTP_PORT=465  SMTP_USER=resend
# SendGrid: SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587 SMTP_USER=apikey

SMTP_HOST=smtp.example.com          # [futura]
SMTP_PORT=587                        # [futura] 587=STARTTLS  465=SSL
SMTP_SECURE=false                    # [futura] true si SMTP_PORT=465
SMTP_USER=                           # [futura]
SMTP_PASS=                           # [futura]
SMTP_FROM=noreply@dermacopilot.com   # [futura]
SMTP_FROM_NAME=Derma Copilot         # [futura]


# ─── Storage de Archivos ──────────────────────────────────────────────────────
# Usado para: fotos de lesiones dérmicas, informes PDF, avatares
#
# STORAGE_PROVIDER acepta: local | s3 | cloudinary
# · local:      almacena en ./uploads/  (solo para desarrollo)
# · s3:         AWS S3 o compatible (MinIO, Cloudflare R2)
# · cloudinary: transformaciones de imagen automáticas (útil para thumbnails)

STORAGE_PROVIDER=local              # [futura] default: local

# ── AWS S3 (o compatible: MinIO, R2) ──────────────────────────────────────────
AWS_REGION=us-east-1                # [futura]
AWS_ACCESS_KEY_ID=                  # [futura]
AWS_SECRET_ACCESS_KEY=              # [futura]
AWS_S3_BUCKET=derma-copilot-media   # [futura]
AWS_S3_ENDPOINT=                    # [futura] solo para MinIO/R2; vacío para AWS real

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=              # [futura]
CLOUDINARY_API_KEY=                 # [futura]
CLOUDINARY_API_SECRET=              # [futura]


# ─── Inteligencia Artificial ──────────────────────────────────────────────────
# Análisis automatizado de lesiones dérmicas y asistencia al diagnóstico

# Anthropic Claude (análisis de imágenes médicas)
ANTHROPIC_API_KEY=                  # [futura]
ANTHROPIC_MODEL=claude-sonnet-4-6   # [futura] default: claude-sonnet-4-6

# Timeout en ms para llamadas a la API de IA (imágenes pueden ser lentas)
AI_TIMEOUT_MS=30000                 # [futura] default: 30000


# ─── URLs del Sistema ─────────────────────────────────────────────────────────

# URL pública de la API (usada en emails y respuestas con links)
API_URL=http://localhost:3000       # [opcional]

# URL del frontend (usada en links de emails: reset password, verificación)
CLIENT_URL=http://localhost:5173    # [opcional]


# =============================================================================
#  Ejemplo de valores para producción (NO usar estos en producción real)
# =============================================================================
#
#  NODE_ENV=production
#  PORT=8080
#  LOG_LEVEL=warn
#
#  JWT_SECRET=<64-char-hex-aleatorio>
#  JWT_EXPIRES_IN=15m
#  JWT_REFRESH_SECRET=<64-char-hex-aleatorio-diferente>
#  JWT_REFRESH_EXPIRES_IN=7d
#
#  DATABASE_URL=postgresql://prod_user:prod_pass@db.internal:5432/derma_prod?sslmode=require
#  REDIS_URL=redis://:prod_redis_pass@redis.internal:6379
#
#  CORS_ORIGIN=https://app.dermacopilot.com
#  BCRYPT_SALT_ROUNDS=14
#  ENCRYPTION_KEY=<64-char-hex-aleatorio>
# =============================================================================
