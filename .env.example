# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Derma Copilot (raíz)
# Copia este archivo como .env y rellena los valores reales.
# NUNCA comitees .env al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Base de datos (PostgreSQL) ────────────────────────────────────────────────
# Supabase:   postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Local:      postgresql://postgres:password@localhost:5432/derma_copilot
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera valores seguros con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_64_bytes
JWT_REFRESH_SECRET=cambia_esto_por_otro_secreto_diferente_de_64_bytes
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Bcrypt ────────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
